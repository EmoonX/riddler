{
  "manifest_version": 3,
  "name": "Riddler",
  "description": "Browser extension for Riddler, the online riddle enhancer.",
  "version": "0.7.3",

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "images/icons/action/default16.png",
    "32": "images/icons/action/default32.png",
    "48": "images/icons/action/default48.png",
    "128": "images/icons/action/default128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/icons/action/default16.png",
      "32": "images/icons/action/default32.png"
    },
    "default_title": "Riddler",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "thirdParty/jquery.min.js",
        "content/port.js",
        "content/blacklist.js",
        "content/credentials.js"
      ]
    }
  ]
}
